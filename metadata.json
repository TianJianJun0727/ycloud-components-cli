{
  "version": "1.0.0",
  "muiVersion": "1.0.0",
  "components": [
    {
      "name": "LoadingButton",
      "nameZh": "加载按钮",
      "descriptionZh": "LoadingButton 基于 MUI Button 封装：在点击后自动进入 loading 状态并展示 CircularProgress，等 onClick（支持 async）执行完毕后自动恢复",
      "inheritMuiProps": "MUI.ButtonProps",
      "props": [
        {
          "loadingColor": {
            "type": "string",
            "description": "loading 图标颜色",
            "required": true,
            "default": "'#fff'",
            "since": "1.0.1",
            "deprecated": false
          }
        }
      ]
    }
  ]
}
