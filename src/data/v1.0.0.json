{
  "version": "1.0.0",
  "components": [
    {
      "name": "Button",
      "nameZh": "按钮",
      "description": "Button component",
      "descriptionZh": "按钮组件",
      "props": [
        {
          "name": "type",
          "type": "'primary' | 'default' | 'dashed' | 'text' | 'link'",
          "required": false,
          "default": "'default'",
          "description": "按钮类型"
        },
        {
          "name": "size",
          "type": "'large' | 'middle' | 'small'",
          "required": false,
          "default": "'middle'",
          "description": "按钮尺寸"
        },
        {
          "name": "disabled",
          "type": "boolean",
          "required": false,
          "default": "false",
          "description": "是否禁用"
        },
        {
          "name": "onClick",
          "type": "() => void",
          "required": false,
          "description": "点击事件"
        }
      ],
      "demos": [
        {
          "name": "basic",
          "description": "基础用法",
          "code": "import { Button } from '@ycloud/components';\n\nexport default () => <Button type=\"primary\">Primary Button</Button>;"
        }
      ]
    },
    {
      "name": "CountrySelect",
      "nameZh": "国家选择器",
      "description": "Country selector component",
      "descriptionZh": "国家选择器组件",
      "props": [
        {
          "name": "value",
          "type": "string",
          "required": false,
          "description": "当前选中的国家代码"
        },
        {
          "name": "onChange",
          "type": "(value: string) => void",
          "required": false,
          "description": "选择变化回调"
        },
        {
          "name": "placeholder",
          "type": "string",
          "required": false,
          "default": "'请选择国家'",
          "description": "占位文本"
        }
      ],
      "demos": [
        {
          "name": "basic",
          "description": "基础用法",
          "code": "import { CountrySelect } from '@ycloud/components';\n\nexport default () => <CountrySelect onChange={(value) => console.log(value)} />;"
        }
      ]
    }
  ]
}
